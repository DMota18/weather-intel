[sqlfluff]
dialect = postgres
templater = jinja
max_line_length = 120

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:templater:jinja:context]
ref = ref
source = source

[sqlfluff:rules]
# Skip rules that conflict with dbt Jinja templates
exclude_rules = RF01, PRS, ST06, AL01
